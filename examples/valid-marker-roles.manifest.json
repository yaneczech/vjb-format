{
  "schema": "com.vjb.bundle",
  "schemaVersion": "1.0.0",
  "bundleId": "example-valid-marker-roles",
  "title": "Marker Roles Example",
  "source": {
    "fileName": "club_loop.mp4",
    "durationMs": 8000,
    "width": 1920,
    "height": 1080,
    "fpsNominal": 30.0,
    "frameCount": 240
  },
  "bake": {
    "targetFps": 120.0,
    "interpolationFactor": 4.0
  },
  "media": {
    "primaryVideo": {
      "path": "media/master.mov",
      "container": "mov",
      "codec": "hap_q",
      "width": 1920,
      "height": 1080,
      "fps": 120.0,
      "frameCount": 960,
      "durationMs": 8000
    }
  },
  "transport": {
    "defaultMode": "once",
    "defaultDirection": 1.0,
    "defaultSpeed": 1.0,
    "seekMode": "frame-accurate",
    "quantizeUnit": "bar"
  },
  "markers": [
    {
      "id": "m_drop",
      "index": 1,
      "frame": 240,
      "roles": ["cue"],
      "segmentEndMarkerId": "m_outro",
      "state": {
        "mode": "loop",
        "direction": 1.0,
        "speed": 1.0
      }
    },
    {
      "id": "q_bar_17",
      "index": 2,
      "frame": 252,
      "roles": ["quantize"],
      "quantize": {
        "unit": "bar",
        "span": 2,
        "phase": 0.5
      }
    },
    {
      "id": "m_hit",
      "index": 3,
      "frame": 264,
      "roles": ["cue", "quantize"],
      "quantize": {
        "unit": "beat",
        "span": 4,
        "phase": 0.75
      },
      "state": {
        "mode": "once",
        "direction": 1.0,
        "speed": 1.0
      }
    },
    {
      "id": "m_outro",
      "index": 4,
      "frame": 360,
      "roles": ["cue"]
    }
  ]
}
