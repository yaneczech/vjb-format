{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vjb-format.github.io/schema/manifest.schema.json",
  "title": "VJB Manifest",
  "description": "Draft schema for VJB manifest.json files.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema",
    "schemaVersion",
    "bundleId",
    "title",
    "source",
    "bake",
    "media",
    "transport",
    "markers"
  ],
  "properties": {
    "schema": {
      "type": "string",
      "const": "com.vjb.bundle"
    },
    "schemaVersion": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "bundleId": {
      "type": "string",
      "minLength": 1
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "source": {
      "$ref": "#/$defs/source"
    },
    "bake": {
      "$ref": "#/$defs/bake"
    },
    "media": {
      "$ref": "#/$defs/media"
    },
    "transport": {
      "$ref": "#/$defs/transport"
    },
    "markers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/marker"
      }
    },
    "custom": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "source": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "fileName",
        "durationMs",
        "width",
        "height",
        "fpsNominal",
        "frameCount"
      ],
      "properties": {
        "fileName": {
          "type": "string",
          "minLength": 1
        },
        "durationMs": {
          "type": "integer",
          "minimum": 0
        },
        "width": {
          "type": "integer",
          "minimum": 1
        },
        "height": {
          "type": "integer",
          "minimum": 1
        },
        "fpsNominal": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "frameCount": {
          "type": "integer",
          "minimum": 1
        },
        "colorSpace": {
          "type": "string"
        },
        "hasAlpha": {
          "type": "boolean"
        },
        "audioEmbedded": {
          "type": "boolean"
        }
      }
    },
    "bake": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "targetFps"
      ],
      "properties": {
        "targetFps": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "interpolationFactor": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "upscaleApplied": {
          "type": "boolean"
        },
        "upscaleFactor": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "aiEngine": {
          "$ref": "#/$defs/aiEngine"
        },
        "hardware": {
          "$ref": "#/$defs/hardware"
        }
      }
    },
    "aiEngine": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "id",
        "version",
        "model"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "model": {
          "type": "string",
          "minLength": 1
        },
        "precision": {
          "type": "string"
        }
      }
    },
    "hardware": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "backend": {
          "type": "string"
        },
        "deviceName": {
          "type": "string"
        },
        "vendor": {
          "type": "string"
        }
      }
    },
    "media": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "primaryVideo"
      ],
      "properties": {
        "primaryVideo": {
          "$ref": "#/$defs/primaryVideo"
        },
        "proxies": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true
          }
        }
      }
    },
    "primaryVideo": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "path",
        "container",
        "codec",
        "width",
        "height",
        "fps",
        "frameCount",
        "durationMs"
      ],
      "properties": {
        "path": {
          "type": "string",
          "pattern": "^(?!/).+"
        },
        "container": {
          "type": "string",
          "enum": [
            "mov"
          ]
        },
        "codec": {
          "type": "string",
          "enum": [
            "hap_q",
            "prores_422",
            "prores_4444"
          ]
        },
        "pixelFormat": {
          "type": "string"
        },
        "width": {
          "type": "integer",
          "minimum": 1
        },
        "height": {
          "type": "integer",
          "minimum": 1
        },
        "fps": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "frameCount": {
          "type": "integer",
          "minimum": 1
        },
        "durationMs": {
          "type": "integer",
          "minimum": 0
        },
        "alpha": {
          "type": "boolean"
        },
        "timecodeBase": {
          "type": "string"
        }
      }
    },
    "transport": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "defaultMode",
        "defaultDirection",
        "defaultSpeed",
        "seekMode"
      ],
      "properties": {
        "defaultMode": {
          "$ref": "#/$defs/mode"
        },
        "defaultDirection": {
          "type": "number",
          "minimum": -1,
          "maximum": 1
        },
        "defaultSpeed": {
          "type": "number",
          "minimum": 0
        },
        "seekMode": {
          "type": "string",
          "enum": [
            "frame-accurate"
          ]
        },
        "quantizeUnit": {
          "type": "string"
        }
      }
    },
    "marker": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "id",
        "index",
        "frame"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "index": {
          "type": "integer",
          "minimum": 1
        },
        "label": {
          "type": "string"
        },
        "color": {
          "type": "string",
          "pattern": "^#[0-9A-Fa-f]{6}([0-9A-Fa-f]{2})?$"
        },
        "frame": {
          "type": "integer",
          "minimum": 0
        },
        "timeMs": {
          "type": "integer",
          "minimum": 0
        },
        "segmentEndMarkerId": {
          "type": "string",
          "minLength": 1
        },
        "state": {
          "$ref": "#/$defs/markerState"
        }
      }
    },
    "markerState": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "direction": {
          "type": "number",
          "minimum": -1,
          "maximum": 1
        },
        "speed": {
          "type": "number",
          "minimum": 0
        },
        "mode": {
          "$ref": "#/$defs/mode"
        },
        "easing": {
          "$ref": "#/$defs/easing"
        }
      }
    },
    "mode": {
      "type": "string",
      "enum": [
        "once",
        "loop",
        "pingpong",
        "hold"
      ]
    },
    "easing": {
      "type": "string",
      "enum": [
        "linear",
        "sine-in",
        "sine-out",
        "sine-in-out",
        "cubic-in",
        "cubic-out",
        "cubic-in-out",
        "bounce-out"
      ]
    }
  }
}
